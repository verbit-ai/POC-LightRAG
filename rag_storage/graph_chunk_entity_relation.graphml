<node id="Rachel's Emails">
  <data key="d0">Rachel's Emails</data>
  <data key="d1">content</data>
  <data key="d2">Rachel's Emails are electronic records that document instructions and arrangements for coal shipments and volume adjustments.</data>
  <data key="d3">chunk-3aa6b92318a7dbc503df2e6bc0457f59</data>
