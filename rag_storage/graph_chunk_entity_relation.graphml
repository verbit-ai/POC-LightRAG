</node>
<node id="35-ton Trucks">
  <data key="d0">35-ton Trucks</data>
  <data key="d1">artifact</data>
  <data key="d2">35-ton Trucks are the specific heavy-duty vehicles used to measure and transport coal shipments according to the standing arrangement.</data>
  <data key="d3">chunk-3aa6b92318a7dbc503df2e6bc0457f59</data>
